<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>オノマトペ学習システム - 機能サンプル</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, "Hiragino Sans", "Yu Gothic", sans-serif;
    background: #f8fafc;
    color: #0f172a;
    min-height: 100vh;
    padding: 20px;
    line-height: 1.6;
  }
  .app {
    max-width: 720px;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 14px;
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
    overflow: hidden;
  }
  header {
    background: #f1f5f9;
    padding: 18px 24px;
    border-bottom: 1px solid #e2e8f0;
  }
  .title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .subtitle { font-size: 12px; color: #64748b; }

  .progress-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
    font-size: 12px;
  }
  .step {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #94a3b8;
  }
  .step-num {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: #e2e8f0;
    color: #64748b;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 11px;
  }
  .step.active { color: #1e3a8a; font-weight: 700; }
  .step.active .step-num { background: #2563eb; color: #fff; }
  .step.done { color: #15803d; }
  .step.done .step-num { background: #15803d; color: #fff; }
  .step-line {
    flex: 1;
    height: 2px;
    background: #e2e8f0;
    min-width: 12px;
  }
  .step-line.done { background: #15803d; }

  main { padding: 28px 24px; min-height: 480px; }

  .question {
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 8px;
    padding: 14px 18px;
    margin-bottom: 20px;
  }
  .question-label {
    font-size: 11px;
    font-weight: 700;
    color: #1e3a8a;
    margin-bottom: 4px;
  }
  .question-text { font-size: 15px; }

  .media-area {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0f172a;
    border-radius: 10px;
    padding: 40px;
    margin-bottom: 20px;
    min-height: 180px;
    color: #fff;
    flex-direction: column;
    gap: 8px;
  }
  .media-emoji {
    font-size: 80px;
    animation: pulse 1.2s infinite;
  }
  .media-emoji.static { animation: none; }
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }
  .media-caption { font-size: 12px; color: #94a3b8; }

  .choices {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 16px;
  }
  .choice {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: #ffffff;
    border: 1.5px solid #cbd5e1;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.15s ease;
    font-size: 14px;
    text-align: left;
    width: 100%;
  }
  .choice:hover { border-color: #2563eb; background: #f8fafc; }
  .choice .letter {
    width: 26px; height: 26px;
    border-radius: 50%;
    background: #f1f5f9;
    color: #475569;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 12px;
    flex-shrink: 0;
  }
  .choice .label { flex: 1; }
  .choice .hint { font-size: 11px; color: #64748b; margin-top: 2px; }
  .choice.correct { border-color: #15803d; background: #dcfce7; }
  .choice.correct .letter { background: #15803d; color: #fff; }
  .choice.wrong { border-color: #dc2626; background: #fef2f2; }
  .choice.wrong .letter { background: #dc2626; color: #fff; }
  .choice:disabled { cursor: not-allowed; }

  .feedback {
    padding: 16px 18px;
    border-radius: 8px;
    margin-bottom: 16px;
    display: none;
  }
  .feedback.show { display: block; }
  .feedback.success { background: #dcfce7; border: 1px solid #15803d; color: #14532d; }
  .feedback.error { background: #fef2f2; border: 1px solid #dc2626; color: #7f1d1d; }
  .feedback-title { font-weight: 700; margin-bottom: 6px; font-size: 13px; }
  .feedback-text { font-size: 13px; }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding-top: 8px;
  }
  button.btn {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 700;
    font-family: inherit;
  }
  .btn-primary {
    background: #2563eb;
    color: #fff;
  }
  .btn-primary:hover { background: #1d4ed8; }
  .btn-primary:disabled { background: #cbd5e1; cursor: not-allowed; }
  .btn-secondary {
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #cbd5e1;
  }
  .btn-secondary:hover { background: #e2e8f0; }

  /* Timeline visualization for Stage 2 */
  .timeline-card {
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 8px;
    border: 1.5px solid;
    cursor: pointer;
    transition: all 0.15s;
  }
  .timeline-card:hover { transform: translateX(2px); }
  .timeline-card.continuous { background: #f0fdfa; border-color: #14b8a6; }
  .timeline-card.momentary { background: #fef9c3; border-color: #eab308; }
  .timeline-card.result { background: #fae8ff; border-color: #a855f7; }
  .timeline-card.selected { box-shadow: 0 0 0 3px #93c5fd; }
  .tl-title {
    font-size: 13px; font-weight: 700; margin-bottom: 4px;
  }
  .tl-desc { font-size: 11px; color: #475569; margin-bottom: 8px; }
  .tl-axis {
    height: 18px;
    background: #fff;
    border-radius: 3px;
    position: relative;
    margin-top: 6px;
  }
  .tl-bar { position: absolute; top: 4px; bottom: 4px; }
  .continuous .tl-bar { left: 5%; right: 5%; background: #5eead4; }
  .momentary .tl-bar { left: 50%; width: 4px; background: #ca8a04; }
  .result .tl-bar { left: 35%; width: 4px; background: #7e22ce; }
  .result .tl-bar-after {
    position: absolute; top: 4px; bottom: 4px;
    left: 35%; right: 5%; background: #d8b4fe;
  }

  /* Debug task */
  .debug-sentence {
    background: #fef2f2;
    border: 2px solid #dc2626;
    border-radius: 10px;
    padding: 18px;
    margin-bottom: 20px;
  }
  .debug-sentence-text {
    font-size: 17px;
    font-style: italic;
  }
  .debug-sentence-text .err {
    color: #dc2626;
    font-weight: 700;
    text-decoration: underline wavy;
  }
  .debug-step {
    background: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 14px;
    margin-bottom: 10px;
  }
  .debug-step-title {
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #1e3a8a;
  }
  .chip-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .chip {
    padding: 6px 12px;
    border-radius: 16px;
    background: #fff;
    border: 1.5px solid #cbd5e1;
    font-size: 12px;
    cursor: pointer;
  }
  .chip.continuous { color: #0f766e; }
  .chip.momentary { color: #854d0e; }
  .chip.result { color: #6b21a8; }
  .chip.selected.continuous { background: #f0fdfa; border-color: #14b8a6; }
  .chip.selected.momentary { background: #fef9c3; border-color: #eab308; font-weight: 700; }
  .chip.selected.result { background: #fae8ff; border-color: #a855f7; }

  /* Result screen */
  .result-screen {
    text-align: center;
    padding: 40px 20px;
  }
  .result-icon { font-size: 64px; margin-bottom: 16px; }
  .result-title { font-size: 22px; font-weight: 700; margin-bottom: 8px; }
  .result-text { color: #64748b; margin-bottom: 24px; }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 700;
    margin-right: 6px;
  }
  .badge-blue { background: #dbeafe; color: #1e3a8a; }
  .badge-teal { background: #ccfbf1; color: #0f766e; }
  .badge-purple { background: #ede9fe; color: #5b21b6; }

  /* Feature judgment panel (Stage 1 4-features) */
  .feature-row {
    background: #ffffff;
    border: 1.5px solid #cbd5e1;
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 10px;
  }
  .feature-row.sense { border-left: 4px solid #2563eb; }
  .feature-row.cont  { border-left: 4px solid #0891b2; }
  .feature-row.act   { border-left: 4px solid #7c3aed; }
  .feature-row.vol   { border-left: 4px solid #dc2626; }
  .feature-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .feature-name {
    font-size: 13px;
    font-weight: 700;
  }
  .feature-desc {
    font-size: 11px;
    color: #64748b;
    margin-bottom: 8px;
  }
  .feature-options {
    display: flex;
    gap: 8px;
  }
  .feature-opt {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #fff;
    border: 1.5px solid #cbd5e1;
    cursor: pointer;
    font-weight: 700;
    font-size: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    font-family: inherit;
  }
  .feature-opt:hover { background: #f1f5f9; }
  .feature-opt.selected { background: #2563eb; color: #fff; border-color: #2563eb; }
  .feature-opt.correct { background: #15803d; color: #fff; border-color: #15803d; }
  .feature-opt.wrong { background: #dc2626; color: #fff; border-color: #dc2626; }
  .feature-feedback {
    font-size: 11px;
    margin-top: 6px;
    display: none;
  }
  .feature-feedback.show { display: block; }
  .feature-feedback.ok { color: #15803d; }
  .feature-feedback.ng { color: #b91c1c; }

  /* Mini profile bars */
  .profile-summary {
    background: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    padding: 12px;
    margin-top: 14px;
    display: none;
  }
  .profile-summary.show { display: block; }
  .profile-summary-title {
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .profile-bar {
    display: grid;
    grid-template-columns: 80px 1fr 24px;
    gap: 8px;
    align-items: center;
    margin-bottom: 6px;
    font-size: 11px;
  }
  .profile-bar .bar-bg {
    height: 10px;
    background: #e2e8f0;
    border-radius: 5px;
    overflow: hidden;
  }
  .profile-bar .bar-fill { height: 100%; }
  .bridge-note {
    margin-top: 10px;
    padding: 8px 10px;
    background: #ecfeff;
    border-radius: 6px;
    font-size: 11px;
    color: #155e75;
    border-left: 3px solid #0891b2;
  }

  /* Sub-stage block */
  .sub-stage {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 14px 16px;
    margin-bottom: 16px;
  }
  .sub-stage-title {
    font-size: 13px;
    font-weight: 700;
    color: #1e3a8a;
    margin-bottom: 4px;
  }
  .sub-stage-desc {
    font-size: 12px;
    color: #64748b;
    margin-bottom: 12px;
  }
  .sub-stage.locked {
    opacity: 0.45;
    pointer-events: none;
    background: #f8fafc;
  }
  .lock-msg {
    font-size: 11px;
    color: #94a3b8;
    font-style: italic;
    margin-top: 6px;
  }

  /* Rationale panel */
  details.rationale {
    margin-top: 24px;
    background: #fffbeb;
    border: 1px solid #fbbf24;
    border-radius: 10px;
    padding: 0;
    overflow: hidden;
  }
  details.rationale[open] { padding-bottom: 14px; }
  details.rationale summary {
    cursor: pointer;
    padding: 12px 16px;
    font-size: 13px;
    font-weight: 700;
    color: #78350f;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 8px;
    user-select: none;
  }
  details.rationale summary::-webkit-details-marker { display: none; }
  details.rationale summary::before {
    content: "▶";
    font-size: 10px;
    transition: transform 0.15s;
  }
  details.rationale[open] summary::before { transform: rotate(90deg); }
  .rationale-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    padding: 0 16px;
  }
  .rationale-block {
    background: #fff;
    border-radius: 8px;
    padding: 12px 14px;
    border: 1px solid #fde68a;
  }
  .rationale-title {
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #78350f;
    padding-bottom: 6px;
    border-bottom: 1px solid #fde68a;
  }
  .rationale-block ul { list-style: none; padding: 0; }
  .rationale-block li {
    font-size: 12px;
    color: #1c1917;
    padding: 4px 0 4px 14px;
    position: relative;
    line-height: 1.5;
  }
  .rationale-block li::before {
    content: "・";
    position: absolute;
    left: 0;
    color: #d97706;
    font-weight: 700;
  }
  @media (max-width: 600px) {
    .rationale-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div class="app">
  <header>
    <div class="title">オノマトペ学習システム</div>
    <div class="subtitle">語彙的意味 → 語彙的アスペクト → 文法 の段階的学習（機能サンプル）</div>
    <div class="progress-bar" id="progressBar"></div>
  </header>

  <main id="mainContent"></main>
</div>

<script>
  const state = {
    stage: 0, // 0: intro, 1-3: stages, 4: debug, 5: complete
    target: 'にっこり',
    answers: {}
  };

  const stages = [
    { id: 1, label: '意味' },
    { id: 2, label: 'アスペクト' },
    { id: 3, label: '文法' },
    { id: 4, label: 'デバッグ' }
  ];

  function renderProgress() {
    const bar = document.getElementById('progressBar');
    bar.innerHTML = '';
    stages.forEach((s, i) => {
      const stepDiv = document.createElement('div');
      const cls = state.stage > s.id ? 'done' :
                  state.stage === s.id ? 'active' : '';
      stepDiv.className = 'step ' + cls;
      stepDiv.innerHTML = `<span class="step-num">${state.stage > s.id ? '✓' : s.id}</span>${s.label}`;
      bar.appendChild(stepDiv);
      if (i < stages.length - 1) {
        const line = document.createElement('div');
        line.className = 'step-line ' + (state.stage > s.id ? 'done' : '');
        bar.appendChild(line);
      }
    });
  }

  function render() {
    renderProgress();
    const main = document.getElementById('mainContent');
    if (state.stage === 0) main.innerHTML = renderIntro();
    else if (state.stage === 1) main.innerHTML = renderStage1();
    else if (state.stage === 2) main.innerHTML = renderStage2();
    else if (state.stage === 3) main.innerHTML = renderStage3();
    else if (state.stage === 4) main.innerHTML = renderDebug();
    else if (state.stage === 5) main.innerHTML = renderComplete();
    bindEvents();
  }

  function renderIntro() {
    return `
      <div style="text-align:center; padding:30px 10px;">
        <div style="font-size:54px; margin-bottom:16px;">😊 💓 ✨</div>
        <div style="font-size:20px; font-weight:700; margin-bottom:10px;">
          感情系オノマトペを 4 段階で学ぶ
        </div>
        <div style="color:#64748b; font-size:14px; margin-bottom:24px;">
          このサンプルでは「<span style="font-weight:700; color:#0f172a;">にっこり</span>」を例に、<br>
          ① 意味 → ② アスペクト → ③ 文法 → ④ デバッグ課題 の流れを体験できます。
        </div>
        <div style="background:#f1f5f9; padding:14px 18px; border-radius:8px; margin-bottom:24px; text-align:left; font-size:13px;">
          <div style="font-weight:700; margin-bottom:6px;">学習対象</div>
          ドキドキ・ワクワク・にっこり・がっかり・キラキラ など、感情系オノマトペ（4/30 メンターMtg合意）
        </div>
        <button class="btn btn-primary" onclick="goNext()">学習をはじめる</button>
      </div>
    `;
  }

  function renderStage1() {
    return `
      <div class="question">
        <div class="question-label">Stage 1：語彙的意味の理解</div>
        <div class="question-text">場面・訳語で意味の見当をつけ、続いて ｛<b>直接感覚, 継続性, 動作性, 意志性</b>｝ の4素性で構造を分析します。</div>
      </div>

      <div class="media-area">
        <div class="media-emoji static">😊</div>
        <div class="media-caption">場面：友達と目が合って、口角を上げて笑う一瞬</div>
      </div>

      <!-- 1A: Translation matching -->
      <div class="sub-stage" id="subA">
        <div class="sub-stage-title">1A：訳語の確認</div>
        <div class="sub-stage-desc">この場面のオノマトペ「<b>にっこり</b>」に最も近い中国語の訳語を選んでください。</div>
        <div class="choices" id="trans1">
          <button class="choice" data-correct="false">
            <span class="letter">A</span>
            <span><span class="label">心怦怦跳</span><div class="hint">緊張・期待で心臓が高鳴る</div></span>
          </button>
          <button class="choice" data-correct="true">
            <span class="letter">B</span>
            <span><span class="label">嫣然一笑 / 微微一笑</span><div class="hint">穏やかに微笑む</div></span>
          </button>
          <button class="choice" data-correct="false">
            <span class="letter">C</span>
            <span><span class="label">失望 / 沮丧</span><div class="hint">期待が外れて落胆する</div></span>
          </button>
          <button class="choice" data-correct="false">
            <span class="letter">D</span>
            <span><span class="label">闪闪发亮</span><div class="hint">光が反射する／目が輝く</div></span>
          </button>
        </div>
        <div class="feedback" id="feedbackA"></div>
      </div>

      <!-- 1B: 4-feature analysis (locked until A is correct) -->
      <div class="sub-stage locked" id="subB">
        <div class="sub-stage-title">1B：4素性プロファイル分析</div>
        <div class="sub-stage-desc">訳語は意味の入口にすぎません。「にっこり」が持つ各素性を判定し、意味の構造を理解します。</div>
        <div class="lock-msg" id="lockMsgB">※ 1Aの訳語が正解になると解除されます。</div>

        <div id="features1" style="margin-top:10px;">
          <div class="feature-row sense" data-feat="sense" data-correct="○">
            <div class="feature-header">
              <span class="feature-name">① 直接感覚</span>
              <div class="feature-options">
                <button class="feature-opt" data-val="○">○</button>
                <button class="feature-opt" data-val="×">×</button>
                <button class="feature-opt" data-val="△">△</button>
              </div>
            </div>
            <div class="feature-desc">五感で直接感じられるか（視覚・聴覚・触覚など）</div>
            <div class="feature-feedback" id="fb-sense"></div>
          </div>

          <div class="feature-row cont" data-feat="cont" data-correct="×">
            <div class="feature-header">
              <span class="feature-name">② 継続性 <span style="font-size:10px; color:#155e75;">★Stage 2 アスペクトへの橋渡し</span></span>
              <div class="feature-options">
                <button class="feature-opt" data-val="○">○</button>
                <button class="feature-opt" data-val="×">×</button>
                <button class="feature-opt" data-val="△">△</button>
              </div>
            </div>
            <div class="feature-desc">時間幅をもって続くか</div>
            <div class="feature-feedback" id="fb-cont"></div>
          </div>

          <div class="feature-row act" data-feat="act" data-correct="○">
            <div class="feature-header">
              <span class="feature-name">③ 動作性</span>
              <div class="feature-options">
                <button class="feature-opt" data-val="○">○</button>
                <button class="feature-opt" data-val="×">×</button>
                <button class="feature-opt" data-val="△">△</button>
              </div>
            </div>
            <div class="feature-desc">動き・行為を伴うか</div>
            <div class="feature-feedback" id="fb-act"></div>
          </div>

          <div class="feature-row vol" data-feat="vol" data-correct="○">
            <div class="feature-header">
              <span class="feature-name">④ 意志性</span>
              <div class="feature-options">
                <button class="feature-opt" data-val="○">○</button>
                <button class="feature-opt" data-val="×">×</button>
                <button class="feature-opt" data-val="△">△</button>
              </div>
            </div>
            <div class="feature-desc">意志的に行えるか</div>
            <div class="feature-feedback" id="fb-vol"></div>
          </div>
        </div>

        <div class="profile-summary" id="profileSummary">
          <div class="profile-summary-title">「にっこり」の語彙的意味プロファイル</div>
          <div class="profile-bar"><span>直接感覚</span><div class="bar-bg"><div class="bar-fill" style="width:95%;background:#2563eb;"></div></div><span style="color:#15803d;font-weight:700;">○</span></div>
          <div class="profile-bar"><span>継続性</span><div class="bar-bg"><div class="bar-fill" style="width:5%;background:#0891b2;"></div></div><span style="color:#dc2626;font-weight:700;">×</span></div>
          <div class="profile-bar"><span>動作性</span><div class="bar-bg"><div class="bar-fill" style="width:90%;background:#7c3aed;"></div></div><span style="color:#15803d;font-weight:700;">○</span></div>
          <div class="profile-bar"><span>意志性</span><div class="bar-bg"><div class="bar-fill" style="width:85%;background:#dc2626;"></div></div><span style="color:#15803d;font-weight:700;">○</span></div>
          <div class="bridge-note">★ <b>継続性 ＝ ×</b> なので、次の Stage 2 では「瞬間型」に分類されることが予測されます。</div>
        </div>
      </div>

      <div class="nav">
        <span></span>
        <button class="btn btn-primary" id="nextBtn1" disabled onclick="goNext()">次へ：アスペクト分類 →</button>
      </div>
    `;
  }

  function renderStage2() {
    return `
      <div class="question">
        <div class="question-label">Stage 2：語彙的アスペクトの分類</div>
        <div class="question-text">「<b>にっこり</b>」の時間的特性は どの型？　タイムラインを見て選んでください。</div>
      </div>

      <div id="timeline-choices">
        <div class="timeline-card continuous" data-key="continuous">
          <div class="tl-title">継続型</div>
          <div class="tl-desc">同じ状態が時間幅をもって続く（例：ドキドキ・キラキラ）</div>
          <div class="tl-axis"><div class="tl-bar"></div></div>
        </div>
        <div class="timeline-card momentary" data-key="momentary">
          <div class="tl-title">瞬間型</div>
          <div class="tl-desc">一瞬で完了し、状態が残らない</div>
          <div class="tl-axis"><div class="tl-bar"></div></div>
        </div>
        <div class="timeline-card result" data-key="result">
          <div class="tl-title">変化結果型</div>
          <div class="tl-desc">瞬間の変化後、結果状態が残る（例：がっかり）</div>
          <div class="tl-axis"><div class="tl-bar"></div><div class="tl-bar-after"></div></div>
        </div>
      </div>

      <div class="feedback" id="feedback2" style="margin-top:16px;"></div>

      <div class="nav">
        <button class="btn btn-secondary" onclick="goPrev()">← 戻る</button>
        <button class="btn btn-primary" id="nextBtn2" disabled onclick="goNext()">次へ：文法の選択 →</button>
      </div>
    `;
  }

  function renderStage3() {
    return `
      <div class="question">
        <div class="question-label">Stage 3：文法形式の選択</div>
        <div class="question-text">空欄に入る最も自然な形を選んでください。<br>
        「彼女は私を見て、<b>にっこり</b> <span style="color:#dc2626; font-weight:700;">[ ？ ]</span> 。」</div>
      </div>

      <div style="background:#f1f5f9; padding:10px 14px; border-radius:6px; margin-bottom:16px; font-size:12px;">
        <span class="badge badge-blue">意味</span>笑顔
        <span class="badge badge-teal" style="margin-left:8px;">アスペクト</span>瞬間型
      </div>

      <div class="choices" id="choices3">
        <button class="choice" data-correct="false" data-key="A">
          <span class="letter">A</span>
          <span><span class="label">している</span><div class="hint">状態の継続を表す（継続型・変化結果型用）</div></span>
        </button>
        <button class="choice" data-correct="true" data-key="B">
          <span class="letter">B</span>
          <span><span class="label">した</span><div class="hint">瞬間動作の完了</div></span>
        </button>
        <button class="choice" data-correct="false" data-key="C">
          <span class="letter">C</span>
          <span><span class="label">だ</span><div class="hint">変化結果の状態（例：がっかりだ）</div></span>
        </button>
        <button class="choice" data-correct="false" data-key="D">
          <span class="letter">D</span>
          <span><span class="label">している間</span><div class="hint">継続中の動作</div></span>
        </button>
      </div>

      <div class="feedback" id="feedback3"></div>

      <div class="nav">
        <button class="btn btn-secondary" onclick="goPrev()">← 戻る</button>
        <button class="btn btn-primary" id="nextBtn3" disabled onclick="goNext()">次へ：デバッグ課題 →</button>
      </div>
    `;
  }

  function renderDebug() {
    return `
      <div class="question" style="background:#fef2f2; border-color:#fca5a5;">
        <div class="question-label" style="color:#7c2d12;">🐛 デバッグ課題：誤用例の説明</div>
        <div class="question-text">下の文には誤りがあります。なぜ誤りかを 3 ステップで説明してください。</div>
      </div>

      <div class="debug-sentence">
        <div class="debug-sentence-text">
          「彼女は私を見て、<span class="err">にっこりしている</span>。」
        </div>
      </div>

      <div class="debug-step">
        <div class="debug-step-title">Step 1：「にっこり」のアスペクト型は？</div>
        <div class="chip-row" id="chips1">
          <button class="chip continuous" data-correct="false" data-key="continuous">継続型</button>
          <button class="chip momentary" data-correct="true" data-key="momentary">瞬間型</button>
          <button class="chip result" data-correct="false" data-key="result">変化結果型</button>
        </div>
      </div>

      <div class="debug-step">
        <div class="debug-step-title">Step 2：「している」が表す意味は？</div>
        <div class="chip-row" id="chips2">
          <button class="chip" data-correct="false" data-key="action">瞬間動作</button>
          <button class="chip" data-correct="true" data-key="state">状態の継続</button>
          <button class="chip" data-correct="false" data-key="future">未来の予定</button>
        </div>
      </div>

      <div class="debug-step">
        <div class="debug-step-title">Step 3：不一致の理由</div>
        <div class="chip-row" id="chips3">
          <button class="chip" data-correct="false" data-key="r1">意味が違うから</button>
          <button class="chip" data-correct="true" data-key="r2">瞬間型は状態を持たないので「している」と矛盾</button>
          <button class="chip" data-correct="false" data-key="r3">敬語ではないから</button>
        </div>
      </div>

      <div class="feedback" id="feedbackD" style="margin-top:16px;"></div>

      <div class="nav">
        <button class="btn btn-secondary" onclick="goPrev()">← 戻る</button>
        <button class="btn btn-primary" id="nextBtnD" disabled onclick="goNext()">提出して結果を見る →</button>
      </div>
    `;
  }

  function renderComplete() {
    return `
      <div class="result-screen">
        <div class="result-icon">🎉</div>
        <div class="result-title">習得完了</div>
        <div class="result-text">
          「にっこり」について 意味 → アスペクト → 文法 の連結が確認できました。<br>
          正しい形：「にっこり<b>した</b>／にっこり<b>する</b>」
        </div>
        <div style="background:#f1f5f9; padding:16px; border-radius:8px; text-align:left; font-size:13px; margin-bottom:20px;">
          <div style="font-weight:700; margin-bottom:8px;">学んだルール</div>
          ・<b>瞬間型</b>のオノマトペには「している」がつかない<br>
          ・<b>継続型</b>（ドキドキ等）と<b>変化結果型</b>（がっかり等）には「している」がつく<br>
          ・「だ」は<b>変化結果型</b>に使える（例：がっかりだ）
        </div>
        <button class="btn btn-primary" onclick="restart()">最初からやり直す</button>
      </div>
    `;
  }

  function bindEvents() {
    // Stage 1: 1A translation MCQ → unlocks 1B feature analysis
    if (state.stage === 1) {
      // Sub-stage 1A: Translation choice
      document.querySelectorAll('#trans1 .choice').forEach(btn => {
        btn.onclick = () => {
          const isCorrect = btn.dataset.correct === 'true';
          document.querySelectorAll('#trans1 .choice').forEach(b => {
            b.disabled = true;
            if (b.dataset.correct === 'true') b.classList.add('correct');
            else if (b === btn) b.classList.add('wrong');
          });
          const fb = document.getElementById('feedbackA');
          fb.classList.add('show', isCorrect ? 'success' : 'error');
          if (isCorrect) {
            fb.innerHTML = '<div class="feedback-title">✓ 正解</div><div class="feedback-text">「にっこり」 ≒ 嫣然一笑／微微一笑。訳語は意味の入口です。次に4素性で構造を分析します。</div>';
            document.getElementById('subB').classList.remove('locked');
            document.getElementById('lockMsgB').style.display = 'none';
          } else {
            fb.innerHTML = '<div class="feedback-title">× もう一度確認しましょう</div><div class="feedback-text">画像をもう一度見てください。心臓の鼓動・落胆・光の反射ではなく、口元の表情に注目してください。</div>';
            // Allow re-try: re-enable buttons after a moment
            setTimeout(() => {
              document.querySelectorAll('#trans1 .choice').forEach(b => {
                b.disabled = false;
                b.classList.remove('correct', 'wrong');
              });
            }, 1500);
          }
        };
      });

      // Sub-stage 1B: 4-feature profile analysis
      const featState = { sense: null, cont: null, act: null, vol: null };
      const featHints = {
        sense: { '○': '視覚で直接観察できる笑顔ですね。', '×': '見た目に表れる動作なので直接感覚は有ります。', '△': '視覚で観察可能なので○です。' },
        cont:  { '○': '「にっこり」は一瞬の動作で持続しません。×が正解です。', '×': '一瞬で完了する動作なので継続性は無し。', '△': '持続しない瞬間動作なので×が正解です。' },
        act:   { '○': '表情を作る動作を伴います。', '×': '口角を上げる動作があるので動作性は有ります。', '△': '動作を伴うので○が正解です。' },
        vol:   { '○': '自分の意志で笑うことができます。', '×': '意志的に笑顔を作れるため意志性は有ります。', '△': '意志的に行えるので○が正解です。' }
      };
      document.querySelectorAll('#features1 .feature-row').forEach(row => {
        const feat = row.dataset.feat;
        const correct = row.dataset.correct;
        row.querySelectorAll('.feature-opt').forEach(opt => {
          opt.onclick = () => {
            row.querySelectorAll('.feature-opt').forEach(o => o.classList.remove('selected', 'correct', 'wrong'));
            const val = opt.dataset.val;
            featState[feat] = val;
            const isOk = val === correct;
            opt.classList.add(isOk ? 'correct' : 'wrong');
            if (!isOk) {
              row.querySelectorAll('.feature-opt').forEach(o => {
                if (o.dataset.val === correct) o.classList.add('correct');
              });
            }
            const fbEl = document.getElementById('fb-' + feat);
            fbEl.classList.remove('ok', 'ng');
            fbEl.classList.add('show', isOk ? 'ok' : 'ng');
            fbEl.innerHTML = (isOk ? '✓ 正解：' : '× 正解は ' + correct + ' ── ') + featHints[feat][val];
            // Check completion
            const allOk = Object.entries(featState).every(([k, v]) => {
              const r = document.querySelector(`#features1 .feature-row[data-feat="${k}"]`);
              return v && v === r.dataset.correct;
            });
            if (allOk) {
              document.getElementById('profileSummary').classList.add('show');
              document.getElementById('nextBtn1').disabled = false;
            } else {
              document.getElementById('nextBtn1').disabled = true;
            }
          };
        });
      });
    }

    // Stage 3: choice buttons
    document.querySelectorAll('#choices3 .choice').forEach(btn => {
      btn.onclick = () => {
        const stage = 3;
        const isCorrect = btn.dataset.correct === 'true';
        document.querySelectorAll(`#choices${stage} .choice`).forEach(b => {
          b.disabled = true;
          if (b.dataset.correct === 'true') b.classList.add('correct');
          else if (b === btn) b.classList.add('wrong');
        });
        const fb = document.getElementById(`feedback${stage}`);
        fb.classList.add('show', isCorrect ? 'success' : 'error');
        if (isCorrect) {
          fb.innerHTML = `<div class="feedback-title">✓ 正解</div><div class="feedback-text">${stage1Feedback(stage)}</div>`;
        } else {
          fb.innerHTML = `<div class="feedback-title">× もう一度確認しましょう</div><div class="feedback-text">${stage1WrongFeedback(stage)}</div>`;
        }
        document.getElementById(`nextBtn${stage}`).disabled = !isCorrect;
      };
    });

    // Stage 2: timeline cards
    document.querySelectorAll('#timeline-choices .timeline-card').forEach(card => {
      card.onclick = () => {
        document.querySelectorAll('.timeline-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        const isCorrect = card.dataset.key === 'momentary';
        const fb = document.getElementById('feedback2');
        fb.classList.add('show');
        fb.classList.remove('success', 'error');
        fb.classList.add(isCorrect ? 'success' : 'error');
        if (isCorrect) {
          fb.innerHTML = `<div class="feedback-title">✓ 正解：瞬間型</div><div class="feedback-text">「にっこり」は一瞬で笑顔をつくる動作で、状態として続かないため瞬間型です。</div>`;
        } else {
          fb.innerHTML = `<div class="feedback-title">× タイムラインをもう一度見てみましょう</div><div class="feedback-text">「にっこり」は笑顔をつくる一瞬の動作で、その後の状態が残るわけではありません。</div>`;
        }
        document.getElementById('nextBtn2').disabled = !isCorrect;
      };
    });

    // Debug task: 3 chip groups
    if (state.stage === 4) {
      const groups = ['chips1', 'chips2', 'chips3'];
      const correct = { chips1: false, chips2: false, chips3: false };
      groups.forEach(gid => {
        document.querySelectorAll(`#${gid} .chip`).forEach(chip => {
          chip.onclick = () => {
            document.querySelectorAll(`#${gid} .chip`).forEach(c => c.classList.remove('selected'));
            chip.classList.add('selected');
            correct[gid] = chip.dataset.correct === 'true';
            updateDebugFeedback(correct);
          };
        });
      });
    }
  }

  function stage1Feedback(stage) {
    if (stage === 3) return '「にっこり」は瞬間型なので、瞬間の完了を表す「した」が自然です。「している」（状態継続）は使えません。';
  }
  function stage1WrongFeedback(stage) {
    if (stage === 3) return '「にっこり」は瞬間型でしたね。「している」は継続型・変化結果型にしかつきません。瞬間の完了を表す形を選んでみてください。';
  }

  function updateDebugFeedback(c) {
    const allCorrect = c.chips1 && c.chips2 && c.chips3;
    const fb = document.getElementById('feedbackD');
    fb.classList.add('show');
    fb.classList.remove('success', 'error');
    if (allCorrect) {
      fb.classList.add('success');
      fb.innerHTML = `<div class="feedback-title">✓ 完璧な説明です</div>
        <div class="feedback-text">
          「にっこり」は瞬間型 → 状態を持たない。<br>
          「している」は状態の継続 → 継続型・変化結果型のみに接続。<br>
          → アスペクトが矛盾するため誤用。正しくは「にっこり<b>した</b>」。
        </div>`;
      document.getElementById('nextBtnD').disabled = false;
    } else {
      fb.classList.add('error');
      const got = [c.chips1, c.chips2, c.chips3].filter(Boolean).length;
      fb.innerHTML = `<div class="feedback-title">${got}/3 正解</div>
        <div class="feedback-text">3ステップ全てが揃うと、誤用の理由を構造的に説明したことになります。もう一度選び直してください。</div>`;
      document.getElementById('nextBtnD').disabled = true;
    }
  }

  function goNext() {
    state.stage++;
    render();
    window.scrollTo(0, 0);
  }
  function goPrev() {
    state.stage = Math.max(0, state.stage - 1);
    render();
  }
  function restart() {
    state.stage = 0;
    render();
  }

  render();
</script>

</body>
</html>
